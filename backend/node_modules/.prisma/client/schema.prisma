// EsquadriAPI - Schema Completo com Módulo de Cálculo
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ORGANIZAÇÃO E USUÁRIOS
// ============================================

model Organization {
  id        String   @id @default(uuid())
  name      String
  plan      Plan     @default(STARTER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  clients      Client[]
  productLines ProductLine[]
  budgets      Budget[]
  orders       Order[]
  transactions Transaction[]
  inventory    InventoryItem[]
  documents    Document[]

  @@map("organizations")
}

enum Plan {
  STARTER
  BUSINESS
  PROFESSIONAL
  ENTERPRISE
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  password       String
  name           String
  role           Role         @default(VIEWER)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  budgets Budget[] @relation("CreatedBy")
  orders  Order[]  @relation("OrderCreator")

  @@map("users")
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  SALES
  FINANCE
  VIEWER
}

// ============================================
// CLIENTES E LEADS
// ============================================

model Client {
  id           String     @id @default(uuid())
  type         ClientType @default(PF)
  name         String
  email        String?
  phone        String?
  document     String?
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  budgets      Budget[]
  orders       Order[]
  transactions Transaction[]
  Document     Document[]

  @@map("clients")
}

enum ClientType {
  PF
  PJ
}

// ============================================
// LINHAS DE PRODUTO E COMPONENTES
// ============================================

model ProductLine {
  id       String  @id @default(uuid())
  name     String // "Suprema Classic", "Gold"
  supplier String // "Alumasa", "Cadan"
  isActive Boolean @default(true)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  profiles    Profile[]
  glasses     Glass[]
  accessories Accessory[]
  typologies  Typology[]

  @@map("product_lines")
}

model Profile {
  id             String          @id @default(uuid())
  code           String // "TRL-INF", "VER-EXT"
  name           String // "Trilho Inferior 38mm"
  category       ProfileCategory
  weightPerMeter Decimal         @db.Decimal(8, 3) // kg/m
  length         Decimal         @default(6000) // mm (barra comercial)
  pricePerKg     Decimal         @db.Decimal(10, 2)

  productLineId String
  productLine   ProductLine @relation(fields: [productLineId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  typologyProfiles TypologyProfile[]

  @@map("profiles")
}

enum ProfileCategory {
  TRACK_LOWER
  TRACK_UPPER
  VERTICAL
  HORIZONTAL
  INTERMEDIATE
  LASTER
  FRAME
  STILE
  RAIL
}

model Glass {
  id         String    @id @default(uuid())
  code       String // "VIC-4", "TEM-6"
  name       String // "Vidro Incolor 4mm"
  type       GlassType
  thickness  Decimal   @db.Decimal(5, 2) // mm
  pricePerM2 Decimal   @db.Decimal(10, 2)

  productLineId String
  productLine   ProductLine @relation(fields: [productLineId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("glasses")
}

enum GlassType {
  FLOAT
  TEMPERED
  LAMINATED
  LOW_E
  REFLECTIVE
  ACOUSTIC
}

model Accessory {
  id           String            @id @default(uuid())
  code         String // "ROL-01", "FEC-02"
  name         String // "Roldana 25mm Dupla"
  category     AccessoryCategory
  unit         String            @default("un")
  pricePerUnit Decimal           @db.Decimal(10, 2)

  productLineId String
  productLine   ProductLine @relation(fields: [productLineId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  typologyAccessories TypologyAccessory[]

  @@map("accessories")
}

enum AccessoryCategory {
  ROLLER
  LOCK
  HINGE
  BRUSH
  HANDLE
  CLOSER
  SEAL
  SCREW
  ANCHOR
  OTHER
}

// ============================================
// TIPOLOGIAS
// ============================================

model Typology {
  id   String  @id @default(uuid())
  code String // "JC-2F", "PG-1F"
  name String // "Janela Correr 2 Folhas"
  type String // JC, JA, JM, PG, PP, PC, PF, FC, DV
  icon String? // emoji ou SVG path

  // Configurações padrão
  defaultHeight Int? // altura padrão em mm
  defaultWidth  Int? // largura padrão em mm

  productLineId String
  productLine   ProductLine @relation(fields: [productLineId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  profiles     TypologyProfile[]
  accessories  TypologyAccessory[]
  calculations Calculation[]

  @@map("typologies")
}

model TypologyProfile {
  id String @id @default(uuid())

  typologyId String
  typology   Typology @relation(fields: [typologyId], references: [id], onDelete: Cascade)

  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Fórmula em JavaScript: "height * 2 + width * 2"
  formula   String
  // Margem de corte em mm
  cutMargin Int    @default(0)

  @@unique([typologyId, profileId])
  @@map("typology_profiles")
}

model TypologyAccessory {
  id String @id @default(uuid())

  typologyId String
  typology   Typology @relation(fields: [typologyId], references: [id], onDelete: Cascade)

  accessoryId String
  accessory   Accessory @relation(fields: [accessoryId], references: [id], onDelete: Cascade)

  // Fórmula: "2" (fixo) ou "height / 600" (variável)
  formula String
  // Quantidade mínima
  minQty  Int    @default(1)

  @@unique([typologyId, accessoryId])
  @@map("typology_accessories")
}

// ============================================
// CÁLCULOS E ORÇAMENTOS
// ============================================

model Calculation {
  id String @id @default(uuid())

  typologyId String
  typology   Typology @relation(fields: [typologyId], references: [id])

  // Dimensões
  width    Int
  height   Int
  quantity Int

  // Opções
  options String? // JSON com opções (tipo vidro, tela, etc)

  // Resultados JSON
  resultJson Json

  // Totais
  totalCost Decimal @db.Decimal(12, 2)
  salePrice Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@map("calculations")
}

model Budget {
  id     String       @id @default(uuid())
  number String       @unique
  status BudgetStatus @default(DRAFT)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  subtotal Decimal @db.Decimal(12, 2)
  discount Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)

  validityDays Int       @default(30)
  validUntil   DateTime?
  notes        String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items BudgetItem[]

  @@map("budgets")
}

enum BudgetStatus {
  DRAFT
  SENT
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

model BudgetItem {
  id       String @id @default(uuid())
  budgetId String
  budget   Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  // Referência ao cálculo
  calculationId String?

  description String
  quantity    Int
  width       Int?
  height      Int?
  unitPrice   Decimal @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@map("budget_items")
}

// ============================================
// PEDIDOS
// ============================================

model Order {
  id     String      @id @default(uuid())
  number String      @unique
  status OrderStatus @default(PENDING)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  totalValue Decimal @db.Decimal(12, 2)
  paidValue  Decimal @default(0) @db.Decimal(12, 2)

  deliveryDate DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("OrderCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items OrderItem[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  APPROVED
  IN_PRODUCTION
  READY
  INSTALLED
  COMPLETED
  CANCELLED
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  description String
  quantity    Int
  width       Int?
  height      Int?
  unitPrice   Decimal @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(12, 2)

  createdAt DateTime @default(now())

  @@map("order_items")
}

// ============================================
// FINANCEIRO
// ============================================

model Transaction {
  id          String              @id @default(uuid())
  type        TransactionType
  category    TransactionCategory
  description String
  amount      Decimal             @db.Decimal(12, 2)
  dueDate     DateTime?
  paidDate    DateTime?
  status      TransactionStatus   @default(PENDING)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionCategory {
  SALE
  SERVICE
  INSTALLATION
  MATERIAL
  LABOR
  RENT
  UTILITY
  SALARY
  TAX
  OTHER
}

enum TransactionStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

// ============================================
// ESTOQUE
// ============================================

model InventoryItem {
  id          String            @id @default(uuid())
  code        String
  name        String
  category    InventoryCategory
  quantity    Decimal           @default(0) @db.Decimal(10, 3)
  unit        String            @default("un")
  minQuantity Decimal?          @db.Decimal(10, 3)
  maxQuantity Decimal?          @db.Decimal(10, 3)
  location    String?
  costPrice   Decimal?          @db.Decimal(10, 2)
  salePrice   Decimal?          @db.Decimal(10, 2)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("inventory_items")
}

enum InventoryCategory {
  PROFILE
  GLASS
  ACCESSORY
  TOOL
  EQUIPMENT
  CONSUMABLE
  OTHER
}

// ============================================
// DOCUMENTOS
// ============================================

model Document {
  id          String    @id @default(uuid())
  type        DocType
  name        String
  description String?
  fileUrl     String?
  validFrom   DateTime?
  validUntil  DateTime?

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("documents")
}

enum DocType {
  CONTRACT
  PROPOSAL
  INVOICE
  RECEIPT
  CERTIFICATE
  OTHER
}
