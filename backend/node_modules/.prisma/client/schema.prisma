// EsquadriAPI - Prisma Schema
// Sistema completo para gestão de esquadrias de alumínio

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ORGANIZAÇÃO E USUÁRIOS
// ============================================

model Organization {
  id        String   @id @default(uuid())
  name      String
  domain    String? // domínio da empresa (subdomain)
  plan      Plan     @default(STARTER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  clients      Client[]
  products     Product[]
  profiles     Profile[]
  glasses      Glass[]
  accessories  Accessory[]
  budgets      Budget[]
  orders       Order[]
  productions  Production[]
  transactions Transaction[]
  inventory    InventoryItem[]
  documents    Document[]
  leads        Lead[]
  tasks        Task[]

  @@map("organizations")
}

enum Plan {
  STARTER
  BUSINESS
  PROFESSIONAL
  ENTERPRISE
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  password       String // hashed
  name           String
  role           Role         @default(VIEWER)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  tasks          Task[]       @relation("Assignee")
  budgetsCreated Budget[]     @relation("CreatedBy")
  ordersCreated  Order[]      @relation("OrderCreator")
  productions    Production[]

  @@map("users")
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  SALES
  PRODUCTION
  FINANCE
  VIEWER
}

// ============================================
// CLIENTES E CRM
// ============================================

model Client {
  id           String        @id @default(uuid())
  type         ClientType    @default(PF)
  name         String
  email        String?
  phone        String?
  document     String? // CPF ou CNPJ
  documentType DocumentType?

  // Endereço
  street       String?
  number       String?
  complement   String?
  neighborhood String?
  city         String?
  state        String?
  zipCode      String?

  // Metadata
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  budgets     Budget[]
  orders      Order[]
  leads       Lead[]
  documents   Document[]
  Transaction Transaction[]

  @@map("clients")
}

enum ClientType {
  PF
  PJ
}

enum DocumentType {
  CPF
  CNPJ
  RG
  IE
}

model Lead {
  id     String      @id @default(uuid())
  name   String
  email  String?
  phone  String?
  source LeadSource?
  stage  LeadStage   @default(NEW)
  score  Int         @default(0) // IA score

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  Client         Client?      @relation(fields: [clientId], references: [id])
  clientId       String?
  Task           Task[]

  @@map("leads")
}

enum LeadSource {
  WEBSITE
  WHATSAPP
  REFERRAL
  FAIR
  GOOGLE
  INSTAGRAM
  FACEBOOK
  COLD_OUTREACH
}

enum LeadStage {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  dueDate     DateTime?
  priority    Priority   @default(MEDIUM)
  status      TaskStatus @default(PENDING)

  assigneeId String?
  assignee   User?   @relation("Assignee", fields: [assigneeId], references: [id])

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("tasks")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  CANCELLED
}

// ============================================
// PRODUTOS E MATERIAIS
// ============================================

model Product {
  id          String      @id @default(uuid())
  code        String
  name        String
  description String?
  type        ProductType
  basePrice   Decimal     @db.Decimal(12, 2)
  isActive    Boolean     @default(true)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  budgetItems BudgetItem[]
  orderItems  OrderItem[]
  tipologies  Tipology[]

  @@map("products")
}

enum ProductType {
  WINDOW
  DOOR
  FACADE
  PORTAL
  GLASS_PARTITION
  CUSTOM
}

model Profile {
  id         String  @id @default(uuid())
  code       String
  name       String
  supplier   String?
  weight     Decimal @db.Decimal(8, 3) // kg/m
  color      String?
  finish     String? // anodizado, pintado, etc
  length     Decimal @db.Decimal(10, 2) // mm
  pricePerKg Decimal @db.Decimal(10, 2)
  isActive   Boolean @default(true)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("profiles")
}

model Glass {
  id              String    @id @default(uuid())
  code            String
  name            String
  type            GlassType
  thickness       Decimal   @db.Decimal(5, 2) // mm
  pricePerSqMeter Decimal   @db.Decimal(10, 2)
  isActive        Boolean   @default(true)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("glasses")
}

enum GlassType {
  FLOAT
  TEMPERED
  LAMINATED
  LOW_E
  REFLECTIVE
  ACOUSTIC
  DOUBLE
}

model Accessory {
  id        String            @id @default(uuid())
  code      String
  name      String
  category  AccessoryCategory
  supplier  String?
  unitPrice Decimal           @db.Decimal(10, 2)
  unit      String            @default("un") // un, m, kg
  isActive  Boolean           @default(true)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("accessories")
}

enum AccessoryCategory {
  LOCK
  HINGE
  ROLLER
  BRUSH
  HANDLE
  CLOSER
  SEAL
  SCREW
  ANCHOR
  OTHER
}

model Tipology {
  id          String      @id @default(uuid())
  code        String
  name        String
  productType ProductType
  width       Decimal     @db.Decimal(10, 2) // mm
  height      Decimal     @db.Decimal(10, 2) // mm
  formula     String? // fórmula de cálculo

  // Composição
  profileId String?
  glassId   String?

  // Preço base
  baseCost  Decimal @db.Decimal(12, 2)
  laborCost Decimal @default(0) @db.Decimal(10, 2)

  // Imagem/3D
  imageUrl String?
  svgData  String? // SVG do desenho técnico

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  isActive   Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  BudgetItem BudgetItem[]
  OrderItem  OrderItem[]

  @@map("tipologies")
}

// ============================================
// ORÇAMENTOS
// ============================================

model Budget {
  id     String       @id @default(uuid())
  number String       @unique // Orçamentos: ORÇ-2024-00001
  status BudgetStatus @default(DRAFT)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  // Valores
  subtotal     Decimal      @db.Decimal(12, 2)
  discount     Decimal      @default(0) @db.Decimal(12, 2)
  discountType DiscountType @default(PERCENTAGE)
  total        Decimal      @db.Decimal(12, 2)

  // Validade
  validityDays Int       @default(30)
  validUntil   DateTime?

  // Notas
  notes String?
  terms String? // termos e condições

  // Acesso
  accessToken   String?   @unique // token para portal do cliente
  accessExpires DateTime?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items BudgetItem[]
  Order Order?

  @@map("budgets")
}

enum BudgetStatus {
  DRAFT
  SENT
  VIEWED
  APPROVED
  REJECTED
  EXPIRED
  CONVERTED
}

enum DiscountType {
  PERCENTAGE
  VALUE
}

model BudgetItem {
  id       String @id @default(uuid())
  budgetId String
  budget   Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  tipologyId String?
  tipology   Tipology? @relation(fields: [tipologyId], references: [id], onDelete: SetNull)

  // Descrição
  description String
  quantity    Int    @default(1)

  // Dimensões
  width  Decimal? @db.Decimal(10, 2)
  height Decimal? @db.Decimal(10, 2)

  // Preços
  unitPrice  Decimal @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)

  // Observações
  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("budget_items")
}

// ============================================
// PEDIDOS E PRODUÇÃO
// ============================================

model Order {
  id     String      @id @default(uuid())
  number String      @unique // PED-2024-00001
  status OrderStatus @default(PENDING)

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  budgetId String? @unique
  budget   Budget? @relation(fields: [budgetId], references: [id], onDelete: SetNull)

  // Valores
  totalValue Decimal @db.Decimal(12, 2)
  paidValue  Decimal @default(0) @db.Decimal(12, 2)

  // Datas
  deliveryDate     DateTime?
  installationDate DateTime?

  // Responsável
  createdById String
  createdBy   User   @relation("OrderCreator", fields: [createdById], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items       OrderItem[]
  productions Production[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  APPROVED
  IN_PRODUCTION
  READY
  INSTALLED
  COMPLETED
  CANCELLED
}

model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  tipologyId String?
  tipology   Tipology? @relation(fields: [tipologyId], references: [id], onDelete: SetNull)

  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(12, 2)

  // Status individual
  status OrderItemStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("order_items")
}

enum OrderItemStatus {
  PENDING
  CUT
  ASSEMBLY
  QUALITY
  READY
  INSTALLED
}

model Production {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Etapas de produção
  stage  ProductionStage  @default(CUTTING)
  status ProductionStatus @default(PENDING)

  // Dados técnicos
  cutList Json? // lista de cortes otimizados
  gCode   String? // código para CNC

  // Tempo estimado
  estimatedMinutes Int?
  startedAt        DateTime?
  finishedAt       DateTime?

  // Responsável
  operatorId String?
  operator   User?   @relation(fields: [operatorId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("productions")
}

enum ProductionStage {
  CUTTING
  MACHINING
  ASSEMBLY
  GLAZING
  HARDWARE
  QUALITY
  PACKAGING
}

enum ProductionStatus {
  PENDING
  IN_PROGRESS
  DONE
  ISSUE
}

// ============================================
// FINANCEIRO
// ============================================

model Transaction {
  id       String              @id @default(uuid())
  type     TransactionType
  category TransactionCategory

  description String
  amount      Decimal @db.Decimal(12, 2)

  // Data
  dueDate  DateTime?
  paidDate DateTime?

  // Status
  status TransactionStatus @default(PENDING)

  // Documento
  documentNumber String?
  documentUrl    String?

  // Classificação
  costCenter String? // obra, cliente, produto

  // Relacionamentos
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  orderId String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("transactions")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionCategory {
  SALE
  SERVICE
  INSTALLATION
  MATERIAL
  LABOR
  RENT
  UTILITY
  SALARY
  TAX
  INSURANCE
  MARKETING
  OTHER
}

enum TransactionStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
  PARTIAL
}

// ============================================
// ESTOQUE
// ============================================

model InventoryItem {
  id       String            @id @default(uuid())
  code     String
  name     String
  category InventoryCategory

  // Estoque
  quantity Decimal @default(0) @db.Decimal(10, 3)
  unit     String  @default("un")

  // Controle
  minQuantity Decimal? @db.Decimal(10, 3)
  maxQuantity Decimal? @db.Decimal(10, 3)
  location    String? // Prateleira A-1, etc

  // Preço
  costPrice Decimal? @db.Decimal(10, 2)
  salePrice Decimal? @db.Decimal(10, 2)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("inventory_items")
}

enum InventoryCategory {
  PROFILE
  GLASS
  ACCESSORY
  TOOL
  EQUIPMENT
  CONSUMABLE
  OTHER
}

// ============================================
// DOCUMENTOS E CONTRATOS
// ============================================

model Document {
  id          String  @id @default(uuid())
  type        DocType
  name        String
  description String?

  // Arquivo
  fileUrl  String?
  fileSize Int?
  mimeType String?

  // Validade
  validFrom  DateTime?
  validUntil DateTime?

  // Cliente
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("documents")
}

enum DocType {
  CONTRACT
  PROPOSAL
  INVOICE
  RECEIPT
  CERTIFICATE
  LICENSE
  RG
  CPF
  CNPJ
  COMPROVANTE
  OTHER
}

// ============================================
// LOGS DE AUDITORIA
// ============================================

model AuditLog {
  id             String   @id @default(uuid())
  action         String // CREATE, UPDATE, DELETE
  entity         String // Order, Budget, etc
  entityId       String
  changes        Json? // { field: [old, new] }
  userId         String?
  userEmail      String?
  organizationId String
  createdAt      DateTime @default(now())

  @@map("audit_logs")
}
